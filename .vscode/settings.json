{
	// -------------------------------------------------------------
	// 1. 공통 에디터 설정
	// -------------------------------------------------------------
	"workbench.colorTheme": "Catppuccin Mocha",
	"workbench.iconTheme": "catppuccin-mocha",
	"editor.insertSpaces": true,
	"editor.tabSize": 4, // 모든 파일의 들여쓰기를 4칸으로 통일
	"editor.formatOnSave": true,

	// 탐색기에서 불필요한 파일/폴더 숨기기 (작업 환경 최적화)
	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/node_modules": true, // JS 패키지 폴더
		"**/__pycache__": true, // Python 캐시
		"**/.venv": true, // Python 가상환경
		"**/dist": true, // 빌드 결과물
		"**/.uv": true, // uv 패키지 매니저 캐시
		"**/.mypy_cache": true,
		"**/.pytest_cache": true,
		// ROOT_CONFIG에서는 하위 프로젝트 폴더를 숨겨서 중복을 방지합니다.
		"database": true,
		"backend": true,
		"frontend": true,
		"docs": true,
		"infra": true
	},

	// 2. Explorer: File Nesting (연관된 설정 파일을 부모 파일 아래로 묶어 깔끔하게 표시)
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		// Frontend: package.json 밑에 프론트엔드 설정 파일들을 그룹화
		"package.json": "pnpm-lock.yaml, .npmrc, biome.json, tsconfig.*, vite.config.*, .env.local",

		// Backend: pyproject.toml 밑에 백엔드 설정 파일들을 그룹화
		"pyproject.toml": "uv.lock, .python-version, .flake8, .env, .env.dev, .env.prod",

		// 공통 환경 변수 및 문서 파일 그룹화
		".env": ".env.*, .gitignore, .dockerignore",
		"README.md": "LICENSE, CONTRIBUTING.md, CHANGELOG.md",

		// React 컴포넌트 구조 정리 (.tsx 파일 아래 연관 파일들)
		"*.tsx": "$(capture).css, $(capture).scss, $(capture).test.tsx, $(capture).stories.tsx"
	},

	// -------------------------------------------------------------
	// 2. Python 설정 (Backend - Ruff & Flake8 호환)
	// -------------------------------------------------------------
	"[python]": {
		"editor.defaultFormatter": "charliermarsh.ruff",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.ruff": "explicit", // 저장 시 Ruff를 통한 자동 수정
			"source.organizeImports.ruff": "explicit" // 저장 시 import 순서 자동 정렬
		},
		// Ruff에서 포맷팅 기능을 활성화
		"ruff.format.args": [],
		"ruff.lint.enable": true
	},
	"[jupyter]": {
		"editor.formatOnSave": true
	},

	// 워크스페이스(SFMS 폴더) 기준으로 백엔드 가상환경을 동적으로 찾도록 설정
	"python.terminal.activateEnvironment": true,
	"python.defaultInterpreterPath": "${workspaceFolder:⚙️ BACKEND}/.venv/bin/python",
	"python.languageServer": "Pylance",
	"python.analysis.typeCheckingMode": "basic",
	"ruff.enableExperimentalCodeActions": true,

	// Code Dependency Visualizer
	"codeDependencyVisualizer.pythonEnabled": true,
	"codeDependencyVisualizer.pythonGraphType": "call", // 함수 호출 그래프
	"codeDependencyVisualizer.showGraphOnStartup": true, // 열면 자동으로 그래프 열기
	"codeDependencyVisualizer.excludeImports": false, // import 의존성도 포함
	"codeDependencyVisualizer.graphLayout": "hierarchical", // 계층형 레이아웃
	"codeDependencyVisualizer.showStatusBar": true,

	// -------------------------------------------------------------
	// 3. Frontend 설정 (React/TS - Biome)
	// -------------------------------------------------------------
	// OS나 버전에 종속되지 않도록 프로젝트 로컬 bin 폴더를 참조
	"biome.lsp.bin": "./frontend/node_modules/.bin/biome",
	"biome.enabled": true,
	"biome.formatOnSave": true,

	// Biome을 기본 포매터로 지정 및 탭 4칸 강제 적용
	"[javascript][javascriptreact][typescript][typescriptreact][json][jsonc][yaml][css]": {
		"editor.tabSize": 4,
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.fixAll.biome": "explicit",
			"source.organizeImports": "explicit",
			"source.organizeImports.biome": "explicit",
			"source.addMissingImports": "explicit"
		}
	},

	// Call Hierarchy 관련 편의 설정
	"js/ts.suggest.autoImports": true,
	"typescript.preferences.includeCompletionsForImportStatements": true,

	// TypeScript/JavaScript에서 Call Hierarchy를 빠르게 쓰기
	"workbench.list.defaultFindMode": "highlight",
	"workbench.list.typeNavigationMode": "automatic",
	"editor.suggestSelection": "first",
	"editor.snippetSuggestions": "top",

	// dependency-cruiser 확장 설정
	"dependency-cruiser.configFile": ".dependency-cruiser.js",
	"dependency-cruiser.runOnSave": true,
	"dependency-cruiser.layout": "hierarchical",
	"dependency-cruiser.maxDepth": 3,
	"dependency-cruiser.exclude": [
		"node_modules",
		"dist",
		"build",
		"**/*.test.*"
	],

	// -------------------------------------------------------------
	// 4. SQL (PostgreSQL)
	// -------------------------------------------------------------
	"sqlfluff.executablePath": "/home/blue/projects/sfms/backend/.venv/bin/sqlfluff",
	"sqlfluff.dialect": "postgres",
	"sqlfluff.linter.run": "onSave",
	"[sql]": {
		"editor.defaultFormatter": "bradymholt.pgformatter",
		"editor.formatOnSave": true
	},
	"pgsql.connectionTimeout": 30,
	"pgsql.showStartNotification": false,
	// -------------------------------------------------------------
	// 5. Markdown 설정
	// -------------------------------------------------------------
	"[markdown]": {
		"editor.defaultFormatter": "DavidAnson.vscode-markdownlint",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.markdownlint": "explicit"
		}
	},
	// markdownlint 상세 작동 방식
	"markdownlint.run": "onType", // 실시간으로 검사 (onSave로 변경 가능)
	"markdownlint.focusMode": false,
	"markdownlint.config": {
		"MD033": { "allowed_elements": ["br", "div", "details"] }, // HTML 태그 일부 허용
		"MD032": false
	},
	"markdown-mermaid.lightModeTheme": "default", // 라이트 모드 테마 (base/forest/dark/default/neutral)
	"markdown-mermaid.darkModeTheme": "dark", // 다크 모드 테마 (기본값)
	"markdown-mermaid.mouseNavigation.enabled": "alt", // 마우스 줌/팬: alt키 누를 때만 (always/alt/never)
	"markdown-mermaid.controls.show": "onHoverOrFocus", // 컨트롤 버튼: 호버/포커스 시 표시 (never/always/onHoverOrFocus)
	// "markdown-mermaid.maxHeight": "500px",         // 다이어그램 최대 높이 제한 (선택적)
	"markdown-mermaid.languages": ["mermaid"], // 인식할 언어 블록 (기본값)
	"markdown.validate.enabled": false,

	// -------------------------------------------------------------
	// 6. yaml 설정
	// -------------------------------------------------------------
	"[yaml]": {
		"editor.tabSize": 4,
		"editor.insertSpaces": true,
		"editor.formatOnSave": true,
		"editor.defaultFormatter": "redhat.vscode-yaml"
	},

	// -------------------------------------------------------------
	// 7. Docker 설정
	// -------------------------------------------------------------
	"docker.showStartNotification": false,

	// -------------------------------------------------------------
	// 8. 아이콘 설정
	// -------------------------------------------------------------
	// Material Icon Theme 및 VSCode Icons에서 pgsql 확장자를 일반 sql 아이콘으로 매핑
	"material-icon-theme.files.associations": {
		"pgsql": "sql"
	},
	"vsicons.associations.files": [
		{
			"icon": "sql",
			"extensions": ["pgsql"],
			"format": "svg"
		}
	],

	// -------------------------------------------------------------
	// 9. 터미널 프로필 설정 (SFMS 프로젝트 맞춤형)
	// -------------------------------------------------------------
	"terminal.integrated.profiles.linux": {
		"SFMS Backend": {
			"path": "mise",
			"args": [
				"exec",
				"--",
				"zsh",
				"-c",
				"cd ${workspaceFolder}/backend && uv run zsh"
			],
			"cwd": "${workspaceFolder}/backend"
		},
		"SFMS Frontend": {
			"path": "mise",
			"args": [
				"exec",
				"--",
				"zsh",
				"-c",
				"cd ${workspaceFolder}/frontend && pnpm exec zsh"
			],
			"cwd": "${workspaceFolder}/frontend"
		},
		"PostgreSQL": {
			"path": "mise",
			"args": [
				"exec",
				"--",
				"zsh",
				"-c",
				"psql -h localhost -U sfms_user sfms; exec bash"
			],
			"cwd": "${workspaceFolder}"
		}
	}
}

# [로컬 개발 전용 설정] 
# IDE(PyCharm, VSCode)에서 직접 실행할 때 사용됩니다.
# 컨테이너 환경에서는 infra/compose/*.yaml의 environment 설정이 이 파일을 덮어씁니다.

DATABASE_URL=postgresql+asyncpg://sfms_usr:pgpass@localhost:5432/sfms_db
REDIS_URL=redis://:rdpass@localhost:6379/0
S3_ENDPOINT=http://localhost:9000

# CORS 설정 (로컬 개발용)
BACKEND_CORS_ORIGINS='["http://localhost:5173", "http://localhost:3000"]'

# MinIO 보안 키 (로컬 기본값)
MINIO_ACCESS_KEY=sfms_usr
MINIO_SECRET_KEY=miniopass

# 1단계: 빌드 스테이지 (Build Stage)
FROM node:24-alpine AS build-stage
WORKDIR /app

# pnpm 설치 및 의존성 복사 [cite: 3, 7]
RUN npm install -g pnpm\
  # 프로젝트 루트를 기준으로 frontend 폴더의 의존성 복사
  COPY frontend/package.json frontend/pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile

# 소스 코드 복사 및 빌드 실행 [cite: 8]
COPY . .
RUN pnpm run build

# 2단계: 실행 스테이지 (Production Stage)
# 빌드된 결과물만 가벼운 nginx로 옮겨서 보안과 용량을 모두 잡습니다.
FROM nginx:alpine
WORKDIR /usr/share/nginx/html

# 1단계에서 빌드된 dist 폴더 내용만 복사
# 빌드된 결과물을 Nginx 기본 경로로 복사
COPY --from=build-stage /app/dist /usr/share/nginx/html

# 설정 및 래퍼 스크립트 복사
COPY ./nginx/conf.d/default.conf /etc/nginx/conf.d/default.conf
COPY ./nginx/scripts/entrypoint-wrapper.sh /usr/local/bin/

RUN chmod +x /usr/local/bin/entrypoint-wrapper.sh

ENTRYPOINT ["/usr/local/bin/entrypoint-wrapper.sh"]
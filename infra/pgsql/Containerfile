FROM groonga/pgroonga:latest-debian-16

#### [수정 1] 패키지 설치 시 임시 DB 데몬이 백그라운드에서 실행되는 것 원천 차단
RUN echo "#!/bin/sh\nexit 101" > /usr/sbin/policy-rc.d && chmod +x /usr/sbin/policy-rc.d

#### 의존성 패키지 설치
RUN apt-get update && \
    apt-mark hold postgresql-16 postgresql-client-16 && \
    apt-get install -y --no-install-recommends locales postgresql-16-cron && \
    sed -i 's/# ko_KR.UTF-8 UTF-8/ko_KR.UTF-8 UTF-8/' /etc/locale.gen && \
    locale-gen ko_KR.UTF-8 && \
    ln -sf /usr/share/zoneinfo/Asia/Seoul /etc/localtime && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# 3. 로케일이 정상적으로 시스템에 생성된 '이후에' 환경변수를 적용합니다.
ENV LANG=ko_KR.UTF-8
ENV LC_ALL=ko_KR.UTF-8
ENV TZ=Asia/Seoul

#### [수정 2] 원인 파악을 위해 쉘 스크립트 삽입을 임시로 주석 처리 (매우 중요)
# COPY scripts/00_configure_system.sh /docker-entrypoint-initdb.d/00_configure_system.sh
# RUN chown postgres:postgres /docker-entrypoint-initdb.d/00_configure_system.sh && \
#     chmod +x /docker-entrypoint-initdb.d/00_configure_system.sh

# #### [수정 3] 컨테이너 실행 설정 (pgroonga를 무조건 먼저 로드하도록 순서 변경)
# CMD ["postgres", \
#     "-c", "shared_preload_libraries=pgroonga,pg_cron", \
#     "-c", "cron.database_name=postgres", \
#     "-c", "cron.timezone=Asia/Seoul"]